  "colorsPage": {
    "brandColors": [
      { "name": "Brand Purple", "hex": "#763784", "var": "bg-[#763784]", "usage": "Primary buttons, Active states, Primary borders, Sidebar" },
      { "name": "Brand Magenta", "hex": "#C62B75", "var": "bg-[#C62B75]", "usage": "Selected states, Link text, Active Icons" },
      { "name": "Deep Purple", "hex": "#5a2a65", "var": "bg-[#5a2a65]", "usage": "Primary Button Hover State, Gradient End" },
      { "name": "App Blue", "hex": "#0EABD4", "var": "bg-[#0EABD4]", "usage": "Courses, Learning, Info screens" },
      { "name": "App Orange", "hex": "#F18E3E", "var": "bg-[#F18E3E]", "usage": "Measure actions, Warm highlights" },
      { "name": "App Green", "hex": "#14BB9A", "var": "bg-[#14BB9A]", "usage": "Guided techniques" },
      { "name": "Light Purple", "hex": "#B9A1CA", "var": "bg-[#B9A1CA]", "usage": "Disabled Buttons, Inactive state icons" },
      { "name": "Surface Purple", "hex": "#F3EDF5", "var": "bg-[#F3EDF5]", "usage": "Input Backgrounds, Secondary section backgrounds" }
    ],
    "neutralColors": [
      { "name": "Dark Text", "hex": "#333333", "var": "bg-[#333333]", "usage": "Headings, Body text on light backgrounds" },
      { "name": "Muted Text", "hex": "#7A7A7A", "var": "bg-[#7A7A7A]", "usage": "Labels, Subtitles, Placeholders" },
      { "name": "Success Green", "hex": "#2EA071", "var": "bg-[#2EA071]", "usage": "Password requirement fulfilled tick" },
      { "name": "White", "hex": "#FFFFFF", "var": "bg-white border", "usage": "Cards, Backgrounds, Primary button text" }
    ],
    "gradients": [
      {
        "name": "Brand Background",
        "tailwindClass": "bg-gradient-to-b from-[#C62B75] to-[#5a2a65]",
        "label": "from-[#C62B75] to-[#5a2a65]"
      },
      {
        "name": "Guided Techniques (Blue)",
        "tailwindClass": "bg-gradient-to-b from-[#0EABD4] to-[#042898]",
        "label": "from-[#0EABD4] to-[#042898]"
      },
      {
        "name": "Measure (Orange)",
        "tailwindClass": "bg-gradient-to-br from-[#F18E3E] to-[#E93B3E]",
        "label": "from-[#F18E3E] to-[#E93B3E]"
      },
      {
        "name": "Play (Cyan)",
        "tailwindClass": "bg-gradient-to-br from-[#11A8B2] to-[#20499C]",
        "label": "from-[#11A8B2] to-[#20499C]"
      },
      {
        "name": "Multi-Day (Red)",
        "tailwindClass": "bg-gradient-to-br from-[#EC5850] via-[#E23455] to-[#D51E5C]",
        "label": "from-[#EC5850] to-[#D51E5C]"
      }
    ]
  },

  "brand": {
    "brandPurple": { "hex": "#763784", "usage": "Primary buttons, active states, primary borders, sidebar" },
    "brandMagenta": { "hex": "#C62B75", "usage": "Selected states, link text, active icons" },
    "deepPurple": { "hex": "#5a2a65", "usage": "Primary button hover, gradient end" },
    "appBlue": { "hex": "#0EABD4", "usage": "Courses, learning, info screens" },
    "appOrange": { "hex": "#F18E3E", "usage": "Measure actions, warm highlights" },
    "appGreen": { "hex": "#14BB9A", "usage": "Guided techniques" },
    "lightPurple": { "hex": "#B9A1CA", "usage": "Disabled buttons, inactive icons" },
    "surfacePurple": { "hex": "#F3EDF5", "usage": "Input backgrounds, secondary section backgrounds" }
  },
  "neutral": {
    "darkText": { "hex": "#333333", "usage": "Headings, body on light" },
    "mutedText": { "hex": "#7A7A7A", "usage": "Labels, subtitles, placeholders" },
    "successGreen": { "hex": "#2EA071", "usage": "Success / password met" },
    "white": { "hex": "#FFFFFF", "usage": "Cards, backgrounds, primary button text" }
  },
  "gradients": {
    "brandBackground": {
      "stops": ["#C62B75", "#5a2a65"],
      "usage": "Onboarding panels, brand vertical"
    },
    "guidedTechniques": {
      "stops": ["#0EABD4", "#042898"],
      "usage": "Learn / guided flows"
    },
    "measure": {
      "stops": ["#F18E3E", "#E93B3E"],
      "usage": "Measure action cards"
    },
    "play": {
      "stops": ["#11A8B2", "#20499C"],
      "usage": "Play action cards"
    },
    "multiDay": {
      "stops": ["#EC5850", "#E23455", "#D51E5C"],
