{
  "expo": {
    "name": "wellness-app",
    "slug": "wellness-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-hearmath-icon.png",
      "backgroundColor": "#311B92",
      "resizeMode": "contain",
      "dark": {
        "backgroundColor": "#311B92"
      }
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/splash-hearmath-icon.png",
        "backgroundColor": "#311B92",
        "resizeMode": "contain",
        "dark": {
          "backgroundColor": "#311B92"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#311B92",
        "foregroundImage": "./assets/icon.png"
      },
      "splash": {
        "image": "./assets/splash-hearmath-icon.png",
        "backgroundColor": "#311B92",
        "resizeMode": "contain",
        "dark": {
          "backgroundColor": "#311B92"
        }
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.anonymous.wellnessapp"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-hearmath-icon.png",
          "backgroundColor": "#311B92",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#311B92"
          },
          "android": {
            "image": "./assets/splash-hearmath-icon.png",
            "backgroundColor": "#311B92",
            "resizeMode": "contain",
            "dark": {
              "backgroundColor": "#311B92"
            }
          },
          "ios": {
            "image": "./assets/splash-hearmath-icon.png",
            "backgroundColor": "#311B92",
            "resizeMode": "contain",
            "dark": {
              "backgroundColor": "#311B92"
            }
          }
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
